# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is blocked by .gitignore.

# OpenAI API key (required for all AI modes)
OPENAI_API_KEY=sk-..

# Which mode to run:
#   text_chat     → type text, see response on screen
#   text_voice    → type text, hear response as voice (needs speaker)
#   speech_speech → speak to Sufi, hear her respond  (needs mic + speaker)
SUFI_MODE=text_chat

# Platform override (auto-detected if not set):
#   windows   → 800×520 windowed, cursor visible
#   pi_zero   → 480×320 fullscreen, cursor hidden
#   pi4       → 1280×720 fullscreen, cursor hidden
#   linux     → 800×520 windowed, cursor visible (generic fallback)
# SUFI_PLATFORM=windows
